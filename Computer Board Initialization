#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define size 6

int main() {

	int comp_board[size][size], i, i2, strhor, strver, strhor2, strver2, strhor3, strver3, condition, check=1;

	srand(time(NULL));

	for (i=0; i<6; i++) {
		for (i2=0; i2<6; i2++) {
			comp_board[i][i2] = 0;    // 6x6 filled with zeros
		}
	}


// 4boat
	strhor = rand()%3;
	strver = rand()%3;

	printf ("%d  %d\n", strhor, strver);

	comp_board[strhor][strver] = 1;   // random starting position
	condition = rand()%2+ 1;

	if (condition == 1) {   // horizontal
		for (i2 = 0; i2 < 3; i2++) {
			strhor++;
			comp_board[strhor][strver] = 1;
		}

	}

	if (condition != 1) {   //vertical
		for (i2 = 0; i2 < 3; i2++) {
			strver++;
			comp_board[strhor][strver] = 1;
		}

	}

// 3boat

	while (check == 1) {
		strhor2 = rand()%4;
		strver2 = rand()%4;

		if (strhor != strhor2) {
			check = 0;
		}
		
		if (strver != strver2) {
			check = 0;
		}
	}

		printf ("%d  %d\n", strhor2, strver2);

		comp_board[strhor2][strver2] = 1;   // random starting position
		condition = rand()%2+ 1;

		if (condition == 1) {   // horizontal
			for (i2 = 0; i2 < 2; i2++) {
				strhor2++;
				comp_board[strhor2][strver2] = 1;
			}

		}

		if (condition != 1) {   //vertical
			for (i2 = 0; i2 < 2; i2++) {
				strver2++;
				comp_board[strhor2][strver2] = 1;
			}

		}
		
    check = 1;  

// 2boat
	while (check == 1) {
		strhor3 = rand()%5;
		strver3 = rand()%5;

		if ((strhor != strhor3) && (strhor2 != strhor3)) {
			check = 0;
		}

		if ((strver != strver3) && (strver2 != strver3)) {
			check = 0;
		}
	}

	printf ("%d  %d\n", strhor3, strver3);

	comp_board[strhor3][strver3] = 1;   // random starting position
	condition = rand()%2+ 1;

	if (condition == 1) {   // horizontal
		comp_board[strhor3=strhor3+ 1][strver3] = 1;
	}

	if (condition != 1) {   //vertical
		comp_board[strhor3][strver3= strver3+ 1] = 1;
	}


	for (i=0; i<6; i++) {
		for (i2=0; i2<6; i2++) {
		// 6x6 filled with zeros
			printf("%d", comp_board[i][i2]);
		}
		printf("\n");
		}

	}
