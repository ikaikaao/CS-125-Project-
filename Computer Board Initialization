#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define size 6

void fourBoat(int comp_board[size][size]);
void threeBoat(int comp_board[size][size]);
void twoBoat(int comp_board[size][size]);

int main() {

    int comp_board[size][size];
    int i, j;

    srand(time(NULL));

    // fill board with zeros
    for (i = 0; i < size; i++) {
        for (j = 0; j < size; j++) {
            comp_board[i][j] = 0;
        }
    }

    fourBoat(comp_board);
    threeBoat(comp_board);
    twoBoat(comp_board);

    // print board
    for (i = 0; i < size; i++) {
        for (j = 0; j < size; j++) {
            printf("%d ", comp_board[i][j]);
        }
        printf("\n");
    }

    return 0;
}


// 4 boat
void fourBoat(int comp_board[size][size]) {

    int i, strhor, strver, condition;

    strhor = rand() % 3;
    strver = rand() % 3;

    printf("%d %d\n", strhor, strver);

    comp_board[strhor][strver] = 1;

    condition = rand() % 2;

    if (condition == 0) {   // horizontal
        for (i = 1; i < 4; i++) {
            comp_board[strhor + i][strver] = 1;
        }
    } else {                // vertical
        for (i = 1; i < 4; i++) {
            comp_board[strhor][strver + i] = 1;
        }
    }
}


// 3 boat
void threeBoat(int comp_board[size][size]) {

    int i, strhor, strver, condition;

    strhor = rand() % 4;
    strver = rand() % 4;

    printf("%d %d\n", strhor, strver);

    comp_board[strhor][strver] = 1;

    condition = rand() % 2;

    if (condition == 0) {
        for (i = 1; i < 3; i++) {
            comp_board[strhor + i][strver] = 1;
        }
    } else {
        for (i = 1; i < 3; i++) {
            comp_board[strhor][strver + i] = 1;
        }
    }
}


// 2 boat
void twoBoat(int comp_board[size][size]) {

    int strhor, strver, condition;

    strhor = rand() % 5;
    strver = rand() % 5;

    printf("%d %d\n", strhor, strver);

    comp_board[strhor][strver] = 1;

    condition = rand() % 2;

    if (condition == 0) {
        comp_board[strhor + 1][strver] = 1;
    } else {
        comp_board[strhor][strver + 1] = 1;
    }
}
