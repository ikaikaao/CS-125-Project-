#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define size 6

void getCompShip(int comp_board[size][size]);

int main() {

    int comp_board[size][size];

    srand(time(NULL));

    getCompShip(comp_board);

    return 0;
}

void getCompShip(int comp_board[size][size]) {

    int i, j, strhor, strver, condition, overlap, h, v, iteration=1;

    while (iteration == 1) {

        // reset board
        for (i = 0; i < size; i++) {
            for (j = 0; j < size; j++) {
                comp_board[i][j] = 0;
            }
        }

        overlap = 0;

        // ---------- 4 BOAT ----------
        strhor = rand() % 3;
        strver = rand() % 3;
        printf("%d  %d\n", strhor, strver);
        condition = rand() % 2;

        for (i = 0; i < 4; i++) {
            h = (condition == 0) ? strhor + i : strhor;
            v = (condition == 0) ? strver : strver + i;
            comp_board[h][v] = 1;
        }

        // ---------- 3 BOAT ----------
        strhor = rand() % 4;
        strver = rand() % 4;
        printf("%d  %d\n", strhor, strver);
        condition = rand() % 2;

        for (i = 0; i < 3; i++) {
            h = (condition == 0) ? strhor + i : strhor;
            v = (condition == 0) ? strver : strver + i;

            if (comp_board[h][v] == 1) {
              overlap = 1;
            }
        }

        if (overlap==1) { 
           continue;
        }

        for (i = 0; i < 3; i++) {
            h = (condition == 0) ? strhor + i : strhor;
            v = (condition == 0) ? strver : strver + i;
            comp_board[h][v] = 1;
        }

        // ---------- 2 BOAT ----------
        strhor = rand() % 5;
        strver = rand() % 5;
        printf("%d  %d\n", strhor, strver);
        condition = rand() % 2;

        for (i = 0; i < 2; i++) {
            h = (condition == 0) ? strhor + i : strhor;
            v = (condition == 0) ? strver : strver + i;

            if (comp_board[h][v] == 1) {
              overlap = 1;
            }
        }

        if (overlap==1) { 
           continue;
        }

        for (i = 0; i < 2; i++) {
            h = (condition == 0) ? strhor + i : strhor;
            v = (condition == 0) ? strver : strver + i;
            comp_board[h][v] = 1;
        }
        iteration = 0;
    }

    // print board
    printf("\nFinal Board:\n");
    for (i = 0; i < size; i++) {
        for (j = 0; j < size; j++) {
            printf("%d ", comp_board[i][j]);
        }
        printf("\n");
    }
}
