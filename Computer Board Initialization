#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define size 6

int main() {

	int comp_board[size][size], i, i2, strhor, strver, condition, iteration=1;

	srand(time(NULL));

    condition = rand()%2+ 1;

	for (i=0; i<6; i++) {
		for (i2=0; i2<6; i2++) {
			comp_board[i][i2] = 0;    // 6x6 filled with zeros
		}
	}
 
 
// 4boat    
	strhor = rand()%3;
	strver = rand()%3;
    
    printf ("%d  %d\n", strhor, strver);
		
	comp_board[strhor][strver] = 1;   // random starting position

	if (condition == 1) {   // horizontal
		for (i2 = 0; i2 < 3; i2++) {
		strhor++;
		comp_board[strhor][strver] = 1;
		}
		
	}

	if (condition != 1) {   //vertical
		for (i2 = 0; i2 < 3; i2++) {
		strver++; 
		comp_board[strhor][strver] = 1;
	    }
			
	}

	for (i=0; i<6; i++) {
		for (i2=0; i2<6; i2++) {
    // 6x6 filled with zeros
			printf("%d", comp_board[i][i2]);
		}
		printf("\n");
	}

}
