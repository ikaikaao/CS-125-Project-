#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define size 6

void getCompShip(int comp_board[size][size]);

void turnComp(int comp_board[size][size]);

int main() {

	int comp_board[size][size], i, j, x;

	srand(time(NULL));

	getCompShip(comp_board);

	printf("\n");
	for (i = 0; i < size; i++) {
		for (j = 0; j < size; j++) {
			printf("%d ", comp_board[i][j]);
		}
		printf("\n");
	}
   
	turnComp(comp_board);  //Should be player board as input

	printf("\n");
	for (i = 0; i < size; i++) {
		for (j = 0; j < size; j++) {
			printf("%d ", comp_board[i][j]);
		}
		printf("\n");
	}
}

void turnComp(int comp_board[size][size]) {  //Using computers board for testing should be player board

	int strhor, strver, iteration, h, v, condition, i, sign;     //All instances with computer board array replace with player board

	printf("\nComputers Turn\n");

	strhor = rand() % 6;
	strver = rand() % 6;
	condition = rand() % 2;
	sign = rand() % 2;

	if (comp_board[strhor][strver] == 1) {   // Hit Case
		comp_board[strhor][strver] = 2;
		iteration = 1;
	} else {   // Miss Case
		iteration = 0;
	}

	while (iteration == 1) {

		for (i = 1; i < 4; i++) {

			if (sign == 0) {
				h = (condition == 0)? strhor + i : strhor;
				v = (condition == 0)? strver : strver + i;
			} else {
				h = (condition == 0)? strhor - i : strhor;
				v = (condition == 0)? strver : strver - i;
			}

			if ((h < 0) || (h >= size) || (v < 0) || (v >= size)) {
				iteration = 0;
				break;
			}

			if (comp_board[h][v] == 1) {
				comp_board[h][v] = 2;
			} else {
				iteration = 0;
				break;
			}
		}
	}
}


void getCompShip(int comp_board[size][size]) {

	int i, j, strhor, strver, condition, overlap, h, v, iteration=1;

	while (iteration == 1) {

		// reset board
		for (i = 0; i < size; i++) {
			for (j = 0; j < size; j++) {
				comp_board[i][j] = 0;
			}
		}

		overlap = 0;

		// ---------- 4 BOAT ----------
		strhor = rand() % 3;
		strver = rand() % 3;
		condition = rand() % 2;

		for (i = 0; i < 4; i++) {
			h = (condition == 0) ? strhor + i : strhor;
			v = (condition == 0) ? strver : strver + i;
			comp_board[h][v] = 1;
		}

		// ---------- 3 BOAT ----------
		strhor = rand() % 4;
		strver = rand() % 4;
		condition = rand() % 2;

		for (i = 0; i < 3; i++) {
			h = (condition == 0) ? strhor + i : strhor;
			v = (condition == 0) ? strver : strver + i;

			if (comp_board[h][v] == 1) {
				overlap = 1;
			}
		}

		if (overlap==1) {
			continue;
		}

		for (i = 0; i < 3; i++) {
			h = (condition == 0) ? strhor + i : strhor;
			v = (condition == 0) ? strver : strver + i;
			comp_board[h][v] = 1;
		}

		// ---------- 2 BOAT ----------
		strhor = rand() % 5;
		strver = rand() % 5;
		condition = rand() % 2;

		for (i = 0; i < 2; i++) {
			h = (condition == 0) ? strhor + i : strhor;
			v = (condition == 0) ? strver : strver + i;

			if (comp_board[h][v] == 1) {
				overlap = 1;
			}
		}

		if (overlap==1) {
			continue;
		}

		for (i = 0; i < 2; i++) {
			h = (condition == 0) ? strhor + i : strhor;
			v = (condition == 0) ? strver : strver + i;
			comp_board[h][v] = 1;
		}
		iteration = 0;
	}
}
